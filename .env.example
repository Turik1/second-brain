# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
ALLOWED_CHAT_ID=your-chat-id
# WEBHOOK_DOMAIN=https://your-domain.com  # set for webhook mode, unset for long polling

# Anthropic (metadata extraction + digests)
ANTHROPIC_API_KEY=your-anthropic-key

# Postgres (Open Brain)
DATABASE_URL=postgresql://openbrain:changeme@postgres:5432/openbrain
POSTGRES_PASSWORD=changeme

# Voyage AI (embeddings)
VOYAGE_API_KEY=your-voyage-api-key

# MCP Server
MCP_ACCESS_KEY=generate-a-random-secret-here

# Server
# PORT=3000
# NODE_ENV=production

# Digest schedule
# DIGEST_TIMEZONE=Europe/Berlin
# DAILY_DIGEST_HOUR=8
# WEEKLY_DIGEST_DAY=0
# AFTERNOON_REMINDER_HOUR=14

# Caddy
DOMAIN=:80
