# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ALLOWED_CHAT_ID=your_telegram_chat_id_here

# Optional: set WEBHOOK_DOMAIN for webhook mode (production)
# Leave unset to use long polling (development)
WEBHOOK_DOMAIN=https://sb.yourdomain.com

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Notion
NOTION_API_KEY=secret_...
NOTION_PARENT_PAGE_ID=your_parent_page_id_here
NOTION_DB_PEOPLE=your_people_database_id_here
NOTION_DB_PROJECTS=your_projects_database_id_here
NOTION_DB_IDEAS=your_ideas_database_id_here
NOTION_DB_ADMIN=your_admin_database_id_here
NOTION_DB_INBOX_LOG=your_inbox_log_database_id_here

# Domain (used by Caddy for TLS)
DOMAIN=sb.yourdomain.com

# Server
PORT=3000
NODE_ENV=production

# Digest schedule
DIGEST_TIMEZONE=Europe/Berlin
DAILY_DIGEST_HOUR=8
WEEKLY_DIGEST_DAY=0

# Classification
BOUNCE_THRESHOLD=0.6

# Postgres (Open Brain)
DATABASE_URL=postgresql://openbrain:changeme@postgres:5432/openbrain
POSTGRES_PASSWORD=changeme

# Voyage AI (embeddings)
VOYAGE_API_KEY=your-voyage-api-key
